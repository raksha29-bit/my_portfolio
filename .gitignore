# Version control ignore list

# OS files
.DS_Store
Thumbs.db
*.log

# Python / Backend
backend/__pycache__/
backend/*.py[cod]
backend/*$py.class
backend/.venv/
backend/venv/
backend/ENV/
backend/env/
backend/.pytest_cache/
backend/.env
backend/portfolio.db

# Node / Frontend
frontend/node_modules/
frontend/jspm_packages/
frontend/web_modules/
frontend/dist/
frontend/build/
frontend/.env
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/.eslintcache
frontend/.stylelintcache

# Local Uploads
backend/app/static/uploads/

